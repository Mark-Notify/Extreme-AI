# ==============================================================================
# Extreme AI v4 — Configuration File (ฉบับเต็ม)
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าของคุณ
#   cp .env.example .env
#
# 🔴 ต้องกรอก (Required)  : MT5_LOGIN, MT5_PASSWORD, MT5_SERVER
# 🟡 แนะนำกรอก (Recommended): DISCORD_WEBHOOK_URL, INITIAL_BALANCE
# 🟢 Optional             : OPENAI_API_KEY, GEMINI_API_KEY (ถ้าเปิด LLM Advisor)
# ==============================================================================

# ==============================================================================
# 1. SYMBOL & TIMEFRAME
# ==============================================================================
SYMBOL=XAUUSDm           # สัญลักษณ์สินทรัพย์ (เช่น XAUUSDm, XAUUSD, EURUSDm)
TIMEFRAME=M1             # กรอบเวลา: M1, M5, M15, M30, H1, H4, D1

# ==============================================================================
# 2. BOT LOOP & DASHBOARD
# ==============================================================================
LOOP_INTERVAL_SEC=1      # ความถี่ loop หลัก (วินาที) — ค่าต่ำ = ตอบสนองเร็ว (ต่ำเกิน = CPU สูง)
AI_LOG_INTERVAL_SEC=5    # บันทึก AI log ทุกกี่วินาที (สำหรับเทรน / replay)
DASHBOARD_REFRESH_SEC=1  # refresh web dashboard ทุกกี่วินาที

# ==============================================================================
# 3. AI MODE & SIGNAL THRESHOLDS
# ==============================================================================

# AI Mode: SAFE | NORMAL | AGGRESSIVE
#   SAFE       = เน้นคุณภาพ, ยิงน้อย, เสี่ยงต่ำ (แนะนำมือใหม่)
#   NORMAL     = สมดุลระหว่างคุณภาพและความถี่ (แนะนำทั่วไป)
#   AGGRESSIVE = ยิงบ่อย, เน้นโอกาส (ต้องการ risk management ที่แน่นหนา)
AI_MODE=NORMAL

# ความมั่นใจขั้นต่ำของ AI ก่อนเข้าไม้ (0.0–1.0)
#   ค่ายิ่งสูง = เข้าไม้น้อยลงแต่แม่นขึ้น
AI_CONFIRM_PROB_UP_THRESHOLD=0.55       # probability ขั้นต่ำสำหรับสัญญาณ BUY
AI_CONFIRM_PROB_DOWN_THRESHOLD=0.55     # probability ขั้นต่ำสำหรับสัญญาณ SELL
AI_CONFIRM_CONFIDENCE_THRESHOLD=0.45    # confidence score ขั้นต่ำ (0–1)
AI_CONFIRM_MACD_MARGIN=0.02             # MACD filter margin (0.0 = ปิด, 0.02 = กรองสัญญาณสวนกระแส)

# จำนวน confirmation factors ขั้นต่ำก่อนยิงสัญญาณ (1–5)
#   1 = หลวม   2 = แนะนำ (EMA + BB หรือ EMA + Stoch)   3+ = เข้มงวด
MIN_CONFIRM_FACTORS=2

# AI probability amplification
#   1.0 = ปิด (raw probability)   3.0 = default   สูงขึ้น = สัญญาณชัดขึ้น แต่อาจเกิด false signal
AI_AMPLIFY_FACTOR=3.0

# จำนวน bar ย้อนหลังสูงสุดในการวิเคราะห์ (live loop)
LOOKBACK_BARS=500

# จำนวน bar ย้อนหลังสำหรับเทรน LSTM (ดึงจาก MT5 โดยตรง)
#   แนะนำ 3000–10000 | ยิ่งมาก = model แม่นกว่า แต่เทรนนานกว่า
TRAIN_BARS=5000

# ==============================================================================
# 4. MT5 CONNECTION  🔴 ต้องกรอก
# ==============================================================================
MT5_SERVER=Exness-MT5Trial17   # ชื่อ server โบรก (ดูใน MT5 > Tools > Options > Server)
MT5_LOGIN=                     # หมายเลขบัญชี MT5
MT5_PASSWORD=                  # รหัสผ่านบัญชี MT5
MT5_DEVIATION=20               # Slippage สูงสุดที่ยอมรับได้ (points)
MT5_MAGIC_NUMBER=123456        # Magic number สำหรับระบุออเดอร์ของบอท

# ==============================================================================
# 5. AUTO TRADING
# ==============================================================================
AUTO_TRADE_ENABLED=true        # true = เปิดเทรดอัตโนมัติ | false = แสดงสัญญาณอย่างเดียว
AUTO_TRADE_VOLUME=0.01         # lot size เริ่มต้น (ใช้เมื่อ position sizing คำนวณไม่ได้)
MANUAL_TRADE_VOLUME=0.01       # lot size เมื่อสั่งเทรดผ่าน dashboard ด้วยตนเอง
MAX_OPEN_TRADES=3              # จำนวนออเดอร์สูงสุดที่เปิดพร้อมกัน

# ==============================================================================
# 6. RISK MANAGEMENT & POSITION SIZING
# ==============================================================================
RISK_PER_TRADE=0.01            # ความเสี่ยงต่อไม้ (0.01 = 1% ของ balance)
ATR_SL_MULTIPLIER=1.5          # ตัวคูณ ATR สำหรับ Stop Loss (ค่าสูง = SL ไกลขึ้น)
ATR_TP_MULTIPLIER=3.0          # ตัวคูณ ATR สำหรับ Take Profit (RR ratio ≈ TP/SL)
ADX_TREND_THRESHOLD=20         # ค่า ADX ขั้นต่ำที่ถือว่ามี trend (0–100, แนะนำ 20–25)

# ทุนตั้งต้น — ใช้สำหรับ drawdown protection  🟡 แนะนำกรอก
#   ตั้งให้ตรงกับยอด balance จริงในบัญชี
INITIAL_BALANCE=10000

# ==============================================================================
# 7. VOLUME LIMITS (Lot Size)
# ==============================================================================
MIN_VOLUME=0.01                # lot ขั้นต่ำ (กำหนดโดยโบรก)
MAX_VOLUME=1.0                 # lot สูงสุดต่อออเดอร์ (ทุน 10K แนะนำ ≤ 1.0)

# ==============================================================================
# 8. TICK CONFIGURATION  (ดูค่าจริงได้ใน MT5 > Symbol Properties > แท็บ Specification)
# ==============================================================================
TICK_VALUE=1.0                 # มูลค่าต่อ 1 point ต่อ 1 lot (XAUUSD ≈ 1.0 USD)
TICK_SIZE=0.1                  # ขนาดขั้นต่ำของการเคลื่อนไหวราคา — ตั้งผิดทำให้สั่งออเดอร์ไม่ได้
                               # ตรวจสอบค่าที่ถูกต้องจาก MT5 > Market Watch > คลิกขวาที่ symbol > Specification

# ==============================================================================
# 9. KELLY CRITERION  (Optional — ปรับ lot size อัตโนมัติตาม win rate)
# ==============================================================================
KELLY_CRITERION_ENABLED=false  # true = เปิดใช้ | false = ปิด (ใช้ RISK_PER_TRADE แทน)
KELLY_FRACTION=0.5             # สัดส่วน Kelly ที่ใช้จริง (0.25–0.5 = Half/Quarter-Kelly)

# ==============================================================================
# 10. SESSION FILTER  (Optional — เทรดเฉพาะเวลาที่ liquidity สูง)
# ==============================================================================
SESSION_FILTER_ENABLED=false   # true = เปิดกรองเวลา | false = เทรดตลอด 24 ชั่วโมง
# ช่วงเวลา UTC ที่อนุญาตให้เทรด (รูปแบบ HH:MM-HH:MM)
#   London session  : 07:00-16:00 UTC
#   New York session: 13:00-22:00 UTC
#   London + NY     : 07:00-17:00 UTC  ← แนะนำสำหรับ Gold
SESSION_ACTIVE_HOURS=07:00-17:00

# ==============================================================================
# 11. DISCORD NOTIFICATIONS  🟡 แนะนำกรอก
# ==============================================================================
# สร้าง Webhook URL ได้ที่: Discord Server > Edit Channel > Integrations > Webhooks
DISCORD_WEBHOOK_URL=

# ==============================================================================
# 12. LOGGING & FILE PATHS
# ==============================================================================
AI_LOG_PATH=logs/ai_log.jsonl          # บันทึก AI decision log (JSONL format)
AI_LAST_STATE_PATH=logs/last_state.json  # บันทึก state ล่าสุด (สำหรับ resume)
LSTM_MODEL_PATH=models/extreme_lstm.keras  # path ของ LSTM model ที่เทรนแล้ว

# ==============================================================================
# 13. LLM ADVISOR  (Optional — ต้องมี API Key)  🟢
# ==============================================================================
LLM_ADVISOR_ENABLED=false      # true = เปิดใช้ GPT/Gemini ยืนยันสัญญาณก่อนเข้าไม้
LLM_REQUIRE_CONSENSUS=false    # true = ต้อง LLM เห็นด้วยจึงจะเทรด | false = แค่แนะนำ

# OpenAI GPT  (ดู key ได้ที่ https://platform.openai.com/api-keys)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini       # ตัวเลือก: gpt-4o-mini (เร็ว/ถูก), gpt-4o (แม่น) — ดูรุ่นล่าสุดที่ platform.openai.com/docs/models

# Google Gemini  (ดู key ได้ที่ https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash  # ตัวเลือก: gemini-2.0-flash (เร็ว/ฟรี/ดีกว่า 1.5), gemini-1.5-pro

# ==============================================================================
# PRESET EXAMPLES
# ==============================================================================

# --- ทุน 10,000 บาท/USD (แนะนำสำหรับมือใหม่) ---
# INITIAL_BALANCE=10000
# RISK_PER_TRADE=0.01       # เสี่ยง 1% = 100 บาท/USD ต่อไม้
# MAX_OPEN_TRADES=2         # expose สูงสุด 2% = 200 บาท/USD พร้อมกัน
# AUTO_TRADE_VOLUME=0.01    # lot เริ่มต้น
# MAX_VOLUME=1.0            # lot สูงสุด
# ATR_SL_MULTIPLIER=1.5
# ATR_TP_MULTIPLIER=3.0     # RR ≥ 1:2
# AI_MODE=NORMAL
# MIN_CONFIRM_FACTORS=2

# --- ทุน 50,000 บาท/USD ---
# INITIAL_BALANCE=50000
# RISK_PER_TRADE=0.01       # เสี่ยง 1% = 500 บาท/USD ต่อไม้
# MAX_OPEN_TRADES=3
# AUTO_TRADE_VOLUME=0.05
# MAX_VOLUME=5.0
# ATR_SL_MULTIPLIER=1.5
# ATR_TP_MULTIPLIER=3.0
# AI_MODE=NORMAL
# MIN_CONFIRM_FACTORS=2

# --- Conservative (เน้นความปลอดภัยสูงสุด) ---
# AI_MODE=SAFE
# RISK_PER_TRADE=0.005      # 0.5% ต่อไม้
# MAX_OPEN_TRADES=2
# AI_CONFIRM_PROB_UP_THRESHOLD=0.65
# AI_CONFIRM_PROB_DOWN_THRESHOLD=0.65
# AI_CONFIRM_CONFIDENCE_THRESHOLD=0.60
# MIN_CONFIRM_FACTORS=3
# SESSION_FILTER_ENABLED=true
# SESSION_ACTIVE_HOURS=07:00-17:00

# ==============================================================================
