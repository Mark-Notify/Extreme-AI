# ==== SYMBOL & TIMEFRAME ====
SYMBOL=XAUUSDm
TIMEFRAME=M1

# loop หลักของบอท (วินาที)
LOOP_INTERVAL_SEC=1        # ให้บอทคิดทุก 1 วิ
AI_LOG_INTERVAL_SEC=5      # เขียน log สำหรับเทรนทุก 5 วิ

# AI modes: 🟢 SAFE / 🟡 NORMAL / 🔴 AGGRESSIVE
AI_MODE=AGGRESSIVE

# ---- AI Confirm thresholds ----
AI_CONFIRM_PROB_UP_THRESHOLD=0.50       # ความมั่นใจของ AI (probability) ที่จะให้เข้าไม้ซื้อ
AI_CONFIRM_PROB_DOWN_THRESHOLD=0.50     # ความมั่นใจของ AI (probability) ที่จะให้เข้าไม้ขาย
AI_CONFIRM_CONFIDENCE_THRESHOLD=0.45    # ความมั่นใจ (confidence 0–1)
AI_CONFIRM_MACD_MARGIN=0.02             # MACD filter (0.0 = แค่ดูทิศ / 0.02 = ต้องไม่สวนแรงเกิน)

# AI probability amplification (1.0 = ปิด, 3.0 = default, สูงขึ้น = สัญญาณชัดขึ้น)
AI_AMPLIFY_FACTOR=3.0

# สูงสุดกี่แท่งย้อนหลังในการวิเคราะห์
LOOKBACK_BARS=500

# refresh socket
DASHBOARD_REFRESH_SEC=1

# ==== MT5 CONFIG ====
MT5_SERVER=Exness-MT5Trial17
MT5_LOGIN=
MT5_PASSWORD=
MT5_DEVIATION=20
MT5_MAGIC_NUMBER=123456

# ==== AI & TRADE ====
AUTO_TRADE_ENABLED=true         # เปิด/ปิด การเทรดอัตโนมัติ
AUTO_TRADE_VOLUME=0.01          # ปริมาณ default (ถ้า position sizing คำนวณไม่ได้)
MANUAL_TRADE_VOLUME=0.1         # ปริมาณการเทรดเมื่อสั่งเทรดด้วยตนเอง
MAX_OPEN_TRADES=10              # จำนวนเทรดสูงสุดที่เปิดพร้อมกัน
RISK_PER_TRADE=0.01             # สัดส่วนความเสี่ยงต่อการเทรดแต่ละครั้ง (เช่น 0.01 = 1%)
ATR_SL_MULTIPLIER=1.5           # ตัวคูณ ATR สำหรับคำนวณจุดตั้ง SL
ATR_TP_MULTIPLIER=3.0           # ตัวคูณ ATR สำหรับคำนวณจุดตั้ง TP
ADX_TREND_THRESHOLD=20          # ค่า ADX ขั้นต่ำเพื่อยืนยันแนวโน้ม
TICK_VALUE=1.0                  # ตรงนี้ต้องเปลี่ยนให้ตรงกับโบรกจริง
TICK_SIZE=0.1                   # เช่น XAUUSDm บางโบรก tick=0.1 หรือ 0.01
MIN_VOLUME=0.01                 # ปริมาณการเทรดขั้นต่ำ
MAX_VOLUME=5                    # ปริมาณการเทรดสูงสุด

# ==== DISCORD ====
DISCORD_WEBHOOK_URL=
# DISCORD_WEBHOOK_URL=

# ==== LOGGING ====
AI_LOG_PATH=logs/ai_log.jsonl
AI_LAST_STATE_PATH=logs/last_state.json

# ==== MODEL ====
LSTM_MODEL_PATH=models/extreme_lstm.keras

# ==== LLM ADVISOR (GPT + Gemini) ====
# เปิดใช้ LLM เพื่อเพิ่มความแม่นยำก่อนเข้าไม้
LLM_ADVISOR_ENABLED=false       # true = เปิดใช้ LLM advisor
LLM_REQUIRE_CONSENSUS=false     # true = ต้องให้ LLM เห็นด้วยจึงจะเข้าไม้

# OpenAI GPT
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini        # หรือ gpt-4o, gpt-3.5-turbo

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash   # หรือ gemini-1.5-pro
