# ==============================================================================
# Extreme AI v4 — Configuration File
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าของคุณ
# cp .env.example .env
# ==============================================================================

# ==== SYMBOL & TIMEFRAME ====
SYMBOL=XAUUSDm
TIMEFRAME=M1

# loop หลักของบอท (วินาที)
LOOP_INTERVAL_SEC=1        # ให้บอทคิดทุก 1 วิ
AI_LOG_INTERVAL_SEC=5      # เขียน log สำหรับเทรนทุก 5 วิ

# AI modes: 🟢 SAFE / 🟡 NORMAL / 🔴 AGGRESSIVE
# SAFE      = เน้นคุณภาพสัญญาณ, ยิงน้อย, เสี่ยงต่ำ
# NORMAL    = สมดุล (แนะนำสำหรับมือใหม่)
# AGGRESSIVE = ยิงบ่อย, เน้นโอกาส (ต้องการ risk management ที่แน่นหนา)
AI_MODE=NORMAL

# ---- AI Confirm thresholds ----
AI_CONFIRM_PROB_UP_THRESHOLD=0.55       # ความมั่นใจของ AI (probability) ที่จะให้เข้าไม้ซื้อ
AI_CONFIRM_PROB_DOWN_THRESHOLD=0.55     # ความมั่นใจของ AI (probability) ที่จะให้เข้าไม้ขาย
AI_CONFIRM_CONFIDENCE_THRESHOLD=0.45    # ความมั่นใจ (confidence 0–1)
AI_CONFIRM_MACD_MARGIN=0.02             # MACD filter (0.0 = แค่ดูทิศ / 0.02 = ต้องไม่สวนแรงเกิน)

# จำนวน confirmation factors ขั้นต่ำก่อนยิงสัญญาณ (1-5)
# 2 = แนะนำ (EMA + BB หรือ EMA + Stoch ต้องยืนยัน)
# 3 = เข้มงวดขึ้น
MIN_CONFIRM_FACTORS=2

# AI probability amplification (1.0 = ปิด, 3.0 = default, สูงขึ้น = สัญญาณชัดขึ้น)
AI_AMPLIFY_FACTOR=3.0

# สูงสุดกี่แท่งย้อนหลังในการวิเคราะห์
LOOKBACK_BARS=500

# refresh socket
DASHBOARD_REFRESH_SEC=1

# ==== MT5 CONFIG ====
MT5_SERVER=Exness-MT5Trial17
MT5_LOGIN=
MT5_PASSWORD=
MT5_DEVIATION=20
MT5_MAGIC_NUMBER=123456

# ==== AI & TRADE (ปรับตามทุน 10,000 บาท/USD) ====
AUTO_TRADE_ENABLED=true         # เปิด/ปิด การเทรดอัตโนมัติ
AUTO_TRADE_VOLUME=0.01          # ปริมาณ default (ถ้า position sizing คำนวณไม่ได้)
MANUAL_TRADE_VOLUME=0.01        # ปริมาณการเทรดเมื่อสั่งเทรดด้วยตนเอง
MAX_OPEN_TRADES=3               # จำนวนเทรดสูงสุดที่เปิดพร้อมกัน (ทุน 10K = 2-3 ไม้)
RISK_PER_TRADE=0.01             # 1% ต่อไม้ = เสี่ยง 100 บาท/USD ต่อไม้ (ทุน 10K)
ATR_SL_MULTIPLIER=1.5           # ตัวคูณ ATR สำหรับคำนวณจุดตั้ง SL
ATR_TP_MULTIPLIER=3.0           # ตัวคูณ ATR สำหรับคำนวณจุดตั้ง TP
ADX_TREND_THRESHOLD=20          # ค่า ADX ขั้นต่ำเพื่อยืนยันแนวโน้ม
TICK_VALUE=1.0                  # ต้องเปลี่ยนให้ตรงกับโบรก (XAUUSD = ~1.0 USD/point/lot)
TICK_SIZE=0.1                   # XAUUSDm บางโบรก tick=0.1 หรือ 0.01
MIN_VOLUME=0.01                 # ปริมาณการเทรดขั้นต่ำ
MAX_VOLUME=1.0                  # ปริมาณการเทรดสูงสุด (ทุน 10K = 1 lot MAX)

# ทุนตั้งต้น (สำหรับ drawdown protection)
# ตั้งเท่ากับยอดบัญชีจริง เช่น 10000
INITIAL_BALANCE=10000

# ==== KELLY CRITERION (Optional) ====
# เปิดใช้ Kelly ให้ AI ปรับ lot size อัตโนมัติตาม win rate
KELLY_CRITERION_ENABLED=false
KELLY_FRACTION=0.5              # Half-Kelly (แนะนำ 0.25-0.5)

# ==== SESSION FILTER ====
# กรองเวลาเทรด เฉพาะ Session ที่มีสภาพคล่องสูง
SESSION_FILTER_ENABLED=false
SESSION_ACTIVE_HOURS=07:00-17:00    # UTC (London + NY = 07:00-17:00 UTC)
# Gold sessions แนะนำ: London 07:00-16:00 UTC, NY 13:00-22:00 UTC

# ==== DISCORD ====
DISCORD_WEBHOOK_URL=

# ==== LOGGING ====
AI_LOG_PATH=logs/ai_log.jsonl
AI_LAST_STATE_PATH=logs/last_state.json

# ==== MODEL ====
LSTM_MODEL_PATH=models/extreme_lstm.keras

# ==== LLM ADVISOR (GPT + Gemini) ====
# เปิดใช้ LLM เพื่อเพิ่มความแม่นยำก่อนเข้าไม้
LLM_ADVISOR_ENABLED=false       # true = เปิดใช้ LLM advisor
LLM_REQUIRE_CONSENSUS=false     # true = ต้องให้ LLM เห็นด้วยจึงจะเข้าไม้

# OpenAI GPT
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini        # หรือ gpt-4o, gpt-3.5-turbo

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash   # หรือ gemini-1.5-pro

# ==============================================================================
# PRESET: ทุน 10,000 บาท/USD — แนะนำ
# ==============================================================================
# RISK_PER_TRADE=0.01       # เสี่ยง 1% = 100 บาท/USD ต่อไม้ → ขาดทุนได้ 100 ครั้งก่อนหมดทุน
# MAX_OPEN_TRADES=2         # เปิดได้ 2 ไม้พร้อมกัน (expose max 2% = 200 บาท)
# ATR_SL_MULTIPLIER=1.5     # SL ห่าง 1.5x ATR ป้องกัน noise
# ATR_TP_MULTIPLIER=3.0     # TP ห่าง 3.0x ATR → RR 1:2 ขึ้นไป
# AI_MODE=NORMAL            # สมดุล quality vs frequency
# MIN_CONFIRM_FACTORS=2     # ต้องผ่าน 2 filter ขึ้นไป
# ==============================================================================
